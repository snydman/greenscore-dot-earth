# GreenScore.earth — Environment Variables
# Copy this file to .env.local and fill in your values.

# Anthropic API key — powers the personalized action plan on the results page.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# (Optional) Override the Claude model used for action plans.
# Defaults to claude-haiku-4-5-20251001 if not set.
# ACTION_PLAN_MODEL=claude-haiku-4-5-20251001

# NREL API key — powers local insights (EV chargers, solar potential).
# Get one at https://developer.nlr.gov/signup/
NREL_API_KEY=
